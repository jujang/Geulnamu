# ====================================
# 🌿 글나무 - 환경변수 템플릿
# ====================================
# 이 파일을 복사해서 .env 파일을 만들고 실제 값을 입력하세요!
# .env 파일은 Git에 올라가지 않습니다.

# 🎯 앱 환경 설정
APP_ENV=development
APP_NAME=글나무
APP_VERSION=1.0.0

# 🔑 카카오 OAuth 키들 (프론트엔드용)
KAKAO_NATIVE_APP_KEY=your_native_app_key_here
KAKAO_JAVASCRIPT_APP_KEY=your_javascript_app_key_here
# ℹ️ REST_API_KEY와 ADMIN_KEY는 백엔드에서 관리됩니다

# 🌐 백엔드 API 설정
API_BASE_URL=https://your-backend-domain.com/api
# 로컬 개발시: http://localhost:8080/api

# 📱 앱 설정
ANDROID_PACKAGE_NAME=com.geulnamu.app
IOS_BUNDLE_ID=com.geulnamu.app
WEB_DOMAIN=https://geulnamu.com

# 🔄 OAuth 리다이렉트 URI
KAKAO_REDIRECT_URI=https://geulnamu.com/auth/callback

# 🛠️ 디버그 설정
DEBUG_MODE=true
LOG_LEVEL=info